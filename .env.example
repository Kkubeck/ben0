# BEN-0 Environment Configuration
# Copy to .env and adjust for your installation

# Database
BEN0_DB_URL=sqlite:///data/ben0.db

# Data directories
BEN0_DATA_DIR=data
BEN0_SYNTHETIC_DIR=data/synthetic
BEN0_RAW_DIR=data/raw
BEN0_PROCESSED_DIR=data/processed
BEN0_DOCUMENTS_DIR=data/documents
BEN0_EXPORTS_DIR=data/exports

# Institution
BEN0_INSTITUTION_NAME=Cascadia Demonstration Botanical Garden
BEN0_INSTITUTION_CODE=CDBG

# Logging
BEN0_LOG_LEVEL=INFO

# Model adapter (mock | ollama | openai_compatible)
BEN0_MODEL_ADAPTER=mock
BEN0_MODEL_NAME=

# Ollama (for local LLM — set adapter to "ollama")
BEN0_OLLAMA_URL=http://localhost:11434
BEN0_OLLAMA_MODEL=gemma3:12b

# For UBCBG deployment, set institution:
# BEN0_INSTITUTION_NAME=UBC Botanical Garden
# BEN0_INSTITUTION_CODE=UBC

# Sensitive data
BEN0_ALLOW_PUBLIC_EXPORT=false
